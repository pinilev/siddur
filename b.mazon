<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ברכת המזון</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;600;700&family=Frank+Ruhl+Libre:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Assistant', sans-serif;
            background-color: #fdfaf6;
            color: #333;
        }
        .prayer-text {
            font-family: 'Frank Ruhl Libre', serif;
            font-size: 1.25rem;
            line-height: 2.2;
        }
        .parchment {
            background-image: linear-gradient(to bottom, #fffdfa, #fdfaf6);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }
    </style>
</head>
<body class="min-h-screen p-4 md:p-8">

    <div class="max-w-2xl mx-auto">
        <header class="parchment rounded-xl p-6 mb-8 border-b-4 border-amber-600 text-center">
            <h1 class="text-3xl font-bold text-amber-900 mb-2">ברכת המזון</h1>
            <div id="date-container" class="text-lg text-amber-800 font-semibold mt-4">
                <span id="loading-date">טוען תאריך עברי...</span>
            </div>
            <div id="event-container" class="mt-2 text-amber-700 italic"></div>
        </header>

        <main class="parchment rounded-xl p-8 leading-loose">
            <div id="prayer-content" class="prayer-text">
                <h2 class="text-2xl font-bold text-amber-900 border-b border-amber-200 pb-2 mb-4 text-center">שיר המעלות</h2>
                <p class="mb-6">שִׁיר הַמַּעֲלוֹת, בְּשׁוּב ה' אֶת שִׁיבַת צִיּוֹן הָיִינוּ כְּחֹלְמִים. אָז יִמָּלֵא שְׂחוֹק פִּינוּ וּלְשׁוֹנֵנוּ רִנָּה, אָז יֹאמְרוּ בַגּוֹיִם הִגְדִּיל ה' לַעֲשׂוֹת עִם אֵלֶּה. הִגְדִּיל ה' לַעֲשׂוֹת עִמָּנוּ הָיִינוּ שְׂמֵחִים. שׁוּבָה ה' אֶת שְׁבִיתֵנוּ כַּאֲפִיקִים בַּנֶּגֶב. הַזֹּרְעִים בְּדִמְעָה בְּרִנָּה יִקְצֹרוּ. הָלוֹךְ יֵלֵךְ וּבָכֹה נֹשֵׂא מֶשֶׁךְ הַזָּרַע, בֹּא יָבֹא בְרִנָּה נֹשֵׂא אֲלֻמֹּתָיו.</p>

                <h2 class="text-2xl font-bold text-amber-900 border-b border-amber-200 pb-2 mb-4 text-center">ברכת הזן</h2>
                <p class="mb-6">בָּרוּךְ אַתָּה ה', אֱלֹהֵינוּ מֶלֶךְ הָעוֹלָם, הַזָּן אֶת הָעוֹלָם כֻּלּוֹ בְּטוּבוֹ בְּחֵן בְּחֶסֶד וּבְרַחֲמִים. הוּא נֹתֵן לֶחֶם לְכָל בָּשָׂר כִּי לְעוֹלָם חַסְדּוֹ. וּבְטוּבוֹ הַגָּדוֹל תָּמִיד לֹא חָסַר לָנוּ וְאַל יֶחְסַר לָנוּ מָזוֹן לְעוֹלָם וָעֶד. בַּעֲבוּר שְׁמוֹ הַגָּדוֹל כִּי הוּא אֵל זָן וּמְפַרְנֵס לַכֹּל וּמֵטִיב לַכֹּל וּמֵכִין מָזוֹן לְכָל בְּרִיּוֹתָיו אֲשֶׁר בָּרָא. בָּרוּךְ אַתָּה ה', הַזָּן אֶת הַכֹּל.</p>
                
                <p class="text-center text-sm text-gray-500 mt-10">... (ניתן להמשיך את נוסח הברכה המלא כאן) ...</p>
            </div>
        </main>
    </div>

    <script>
        async function fetchHebrewDate() {
            const dateContainer = document.getElementById('loading-date');
            const eventContainer = document.getElementById('event-container');
            
            try {
                // Fetching from Hebcal API
                const response = await fetch('https://www.hebcal.com/converter?cfg=json&date=now&g2h=1&strict=1');
                const data = await response.json();
                
                if (data) {
                    const hebrewDateStr = `${data.hd} ב${data.hm} ${data.hy}`;
                    dateContainer.innerText = `היום: ${hebrewDateStr}`;
                    
                    // Check for holidays or special events
                    if (data.events && data.events.length > 0) {
                        eventContainer.innerHTML = `<span class="bg-amber-100 px-3 py-1 rounded-full text-sm font-bold border border-amber-200">✨ ${data.events.join(', ')}</span>`;
                    }
                }
            } catch (error) {
                console.error("Error fetching date:", error);
                dateContainer.innerText = "לא ניתן לטעון תאריך עברי כרגע";
            }
        }

        // Initialize on load
        window.onload = fetchHebrewDate;
    </script>
</body>
</html>
